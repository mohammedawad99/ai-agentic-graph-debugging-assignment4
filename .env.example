# Copy to .env and fill locally. NEVER commit a real .env (see .gitignore).
# No secrets are required for the skeleton/requirements-audit stage.

# --- LLM provider (used only in the later agent-workflow stage) ---
# Choose ONE provider for the agent workflow stage.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Model selection (placeholder; confirmed during the agent stage) ---
# Latest/most capable Claude models recommended for the agent workflow.
LLM_MODEL=claude-opus-4-8

# --- Optional: token accounting mode for the efficiency experiment ---
# measured | estimated | manual
TOKEN_ACCOUNTING_MODE=measured
