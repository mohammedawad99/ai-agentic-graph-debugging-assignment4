# Copy to .env and fill locally. NEVER commit a real .env (see .gitignore).
#
# IMPORTANT: the final submitted workflow is DETERMINISTIC and uses NO LLM / NO paid API.
# The graph-guided agent (src/ex04_graph_debugger/graph_guided_agent.py) and the centrality
# extension run with llm_used=false and api_cost_usd=0. None of the values below are required
# to reproduce the repository (uv sync --extra dev; uv run pytest). They are optional placeholders
# only, in case someone later wires in an LLM backend — leave them empty for the standard run.

# --- Optional, unused by default ---
GRAPHIFY_API_KEY=
LLM_API_KEY=
LLM_MODEL=

# No secrets. No provider key is needed for the standard reproduction.
