# Target source: target_repo/luigi_buggy/ is INTENTIONALLY TRACKED as the selected buggy
# target (vendored for reproducibility; D-007). Only stray/alternate clone paths are ignored.
target_repo/luigi/
target_repo/src/

# Large generated artifacts (keep folders via .gitkeep; ignore heavy outputs)
artifacts/graphify/*.json
# ...but the required Stage 5 Graphify artifacts ARE tracked deliberately (D-008 / OD-5):
!artifacts/graphify/graph.json
!artifacts/graphify/.graphify_labels.json
!artifacts/graphify/manifest.json
artifacts/screenshots/*.png
artifacts/screenshots/*.jpg
artifacts/validation/*.log
# ...but these workflow trace logs are tracked deliberately as evidence (D-011 / D-012):
!artifacts/validation/baseline_naive_trace.log
!artifacts/validation/graph_guided_agent_trace.log

# Obsidian local workspace state
obsidian/.obsidian/
